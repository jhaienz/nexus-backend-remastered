# Database
DATABASE_URL=postgresql://user:pass@localhost:5432/nexus

# Auth
JWT_ACCESS_SECRET=change-me-64-char-random-string
JWT_REFRESH_SECRET=change-me-64-char-random-string-different

# Cloudflare R2
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key
R2_SECRET_ACCESS_KEY=your-r2-secret-key
R2_BUCKET_NAME=nexus-pdfs
R2_PUBLIC_URL=https://your-bucket.r2.dev

# Resend
RESEND_API_KEY=re_your_api_key
EMAIL_FROM=noreply@yourdomain.com

# App
FRONTEND_URL=http://localhost:3000
# Optional comma-separated extra origins, for example Vercel preview domains
FRONTEND_URLS=
PORT=3001
